project:
  type: website
  output-dir: docs

website:
  title: "Rachana Talekar"
  navbar:
    background: primary
    search: true
    left:
      - text: "About"
        href: index.qmd
      - text: "Experience"
        href: exp.qmd
      - text: "Research"
        href: research.qmd
      - text: "Academic"
        href: teach.qmd
    right:
      - text: "Contact"
        href: contact.qmd
format:
  html:
    theme: journal
    css: styles.css
    toc: true
    toc-location: right
    toc-depth: 3
    page-layout: full
    grid:
      body-width: 900px
      margin-width: 250px
    code-link: true
    smooth-scroll: true
     # Mobile-specific configurations
    meta:
      viewport: "width=device-width, initial-scale=1.0"
    
    # Responsive behavior
    collapse-below: lg
    
    # Enhanced readability
    mainfont: "Arial, sans-serif"
    monofont: "Courier New, monospace"
    
    # Link and interaction improvements
    link-external-icon: true
    link-external-newwindow: true
